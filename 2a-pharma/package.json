    "cross-env": "^10.1.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "thirty-two": "^1.0.2",
    "totp-generator": "^2.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4"
  }
