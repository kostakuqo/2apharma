{
  "name": "2a-pharma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"if(require('fs').existsSync('out')) require('fs').writeFileSync('out/.nojekyll', '')\"",
    "predeploy": "npm run build",
    "deploy": "cross-env GITHUB_PAGES=true next build && npx gh-pages -d out -b gh-pages --dotfiles",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
